        (proc-arg 9 "GimpParamDrawable" "GimpDrawable" "sample-drawable" "Disegnabile campione" "Disegnabile campione (dovrebbe essere di tipo RGB o RGBA)" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "hold-inten" "Mantieni l'_intensitÃ " "Mantiene i livelli di intensitÃ  della luminositÃ " 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "orig-inten" "I_ntensitÃ  originale" "VERO: mantiene la luminositÃ  dei livelli di intensitÃ  originali, FALSO: mantiene l'intensitÃ  dei livelli di ingresso" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "rnd-subcolors" "Us_a subcolori" "VERO: utilizza tutti i sottocolori della stessa intensitÃ , FALSO: utilizza solo un colore per intensitÃ " 3 0)
        (proc-arg 5 "GParamBoolean" "gboolean" "guess-missing" "Smussa i cam_pioni" "VERO: indovina i colori del campione per i valori di intensitÃ  mancanti, FALSO: usa solo i colori trovati nel campione" 3 1)
